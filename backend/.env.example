# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas - replace with your connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/quantira?retryWrites=true&w=majority

# Redis for BullMQ queue
REDIS_URL=rediss://default:<password>@<host>:6379

# Upstash Redis REST for cache
UPSTASH_REDIS_REST_URL=https://<host>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Require services at startup
REQUIRE_REDIS=true
REQUIRE_DB=true

# groq API
GROQ_API_KEY=sk-ant-xxxxxxxxxxxx

# Scraping config
SEBI_BASE_URL=https://www.sebi.gov.in
BSE_BASE_URL=https://www.bseindia.com
MCA_BASE_URL=https://www.mca.gov.in
NSE_BASE_URL=https://www.nseindia.com

# Rate limiting for scraping (ms between requests)
SCRAPE_DELAY_MS=1500

# PDF storage (use local path for dev, S3 bucket name for prod)
PDF_STORAGE_PATH=./storage/pdfs

# Report generation
REPORT_OUTPUT_PATH=./storage/reports

# Cache TTL in seconds (24 hours)
CACHE_TTL=86400

# Job timeout in ms (90 seconds per spec)
JOB_TIMEOUT_MS=90000
